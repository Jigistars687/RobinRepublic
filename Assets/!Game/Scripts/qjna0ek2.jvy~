using System.Collections.Generic;
using UnityEngine;

csharp Assets\!Game\Scripts\SpaceCheck.cs
using System.Collections.Generic;
using System.Linq;
using UnityEngine;

public class SpaceCheck : MonoBehaviour
{
    public Vector3 boxSize;
    [Tooltip("Слои, которые считаются препятствием для проверки")]
    public LayerMask obstacleLayer;

    [Tooltip("Слои, которые нужно игнорировать (например, Ground)")]
    [SerializeField] private LayerMask ignoreLayerMask;

    [Tooltip("Цвет превью при невозможности поставить объект")]
    [SerializeField] private Color invalidColor = Color.red;

    public bool canPlace = true;

    private List<MeshRenderer> _renderers;
    private List<Color> _originalColors;

    private void Start()
    {
        boxSize = transform.localScale;
        CacheRenderersAndColors();
    }

    private void CacheRenderersAndColors()
    {
        _renderers = new List<MeshRenderer>();
        _originalColors = new List<Color>();

        // Ищем рендереры у родительского здания (SpaceCheck обычно лежит в дочернем объекте)
        var building = GetComponentInParent<Building>();
        if (building != null)
            _renderers.AddRange(building.GetComponentsInChildren<MeshRenderer>(true));
        else
            _renderers.AddRange(GetComponentsInChildren<MeshRenderer>(true));

        foreach (var r in _renderers)
        {
            // Используем renderer.material чтобы получить экземпляр материала для данного рендера.
            // Сохраняем текущий цвет, чтобы восстановить позже.
            if (r != null && r.material != null)
                _originalColors.Add(r.material.color);
            else
                _originalColors.Add(Color.white);
        }
    }

    public void CanPlaceCheck()
    {
        Collider[] colliders = Physics.OverlapBox(transform.position, boxSize / 2f, transform.rotation, obstacleLayer);

        // по умолчанию считаем, что можно ставить
        canPlace = true;

        if (colliders.Length > 0)
        {
            foreach (var col in colliders)
            {
                // игнорируем объекты на слоях, указанных в ignoreLayerMask
                if ((ignoreLayerMask.value & (1 << col.gameObject.layer)) != 0)
                    continue;

                // игнорируем триггерные коллайдеры (при необходимости убрать)
                if (col.isTrigger)
                    continue;

                // нашли непроходимый объект -> нельзя ставить
                canPlace = false;
                Debug.Log($"Препятствие: {col.gameObject.name} (слой {LayerMask.LayerToName(col.gameObject.layer)}, тег {col.gameObject.tag})");
                // не делаем `return` — продолжим проверять, чтобы вывести все препятствия (можно убрать)
            }
        }
        else
        {
            Debug.Log("Место пустое (нет коллайдеров в области).");
        }

        // Обновляем цвет превью: красный если нельзя ставить, иначе восстанавливаем оригинальные цвета
        if (!canPlace)
            ApplyPreviewColor(invalidColor);
        else
            RestoreOriginalColors();
    }

    private void ApplyPreviewColor(Color color)
    {
        if (_renderers == null || _originalColors == null)
            CacheRenderersAndColors();

        for (int i = 0; i < _renderers.Count; i++)
        {
            var r = _renderers[i];
            if (r == null) continue;

            // material создаёт экземпляр материала для данного рендера — безопасно менять цвет превью
            if (r.material != null)
            {
                r.material.color = color;
            }
        }
    }

    private void RestoreOriginalColors()
    {
        if (_renderers == null || _originalColors == null) return;

        for (int i = 0; i < _renderers.Count; i++)
        {
            var r = _renderers[i];
            if (r == null) continue;

            if (r.material != null && i < _originalColors.Count)
            {
                r.material.color = _originalColors[i];
            }
        }
    }

    private void OnDisable()
    {
        // Восстанавливаем цвета при отключении компонента
        RestoreOriginalColors();
    }

    private void OnDestroy()
    {
        RestoreOriginalColors();
    }

    private void Update()
    {
        // Оставил вызов проверки закомментированным — включите при необходимости
        // CanPlaceCheck();
    }

    // Для отладки: визуализируем область проверки в сцене
    private void OnDrawGizmosSelected()
    {
        Gizmos.color = canPlace ? new Color(0, 1, 0, 0.25f) : new Color(1, 0, 0, 0.25f);
        Gizmos.matrix = Matrix4x4.TRS(transform.position, transform.rotation, Vector3.one);
        Gizmos.DrawCube(Vector3.zero, boxSize);
    }
}